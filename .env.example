# RPC
RPC_HTTP_URL=https://api.mainnet-beta.solana.com
RPC_WS_URL=wss://api.mainnet-beta.solana.com

# Wallet (base58 encoded 64-byte secret key)
WALLET_PRIVATE_KEY=

# Programs
PUMPFUN_PROGRAM_ID=6EF8rrecthR5Dkzon8Nwu78hRvfCKubJ14M5uBEwF6P
PUMPSWAP_PROGRAM_ID=11111111111111111111111111111111

# Log detection
MIGRATION_LOG_KEYWORDS=migrate,migration,initialize_pool,create_pool
MIGRATION_DISCRIMINATORS=

# Trading
QUOTE_MINT=So11111111111111111111111111111111111111112
BUY_AMOUNT_SOL=0.2
SLIPPAGE_BPS=300
PRIORITY_FEE_MICROLAMPORTS=50000
AUTO_SELL_ENABLED=true
TAKE_PROFIT_PCT=40
STOP_LOSS_PCT=20
POSITION_CHECK_INTERVAL_MS=5000
MAX_OPEN_POSITIONS=1
TRADE_COOLDOWN_MS=2500

# Optional filters
REQUIRE_PUMPFUN_HINT=true
SKIP_SAME_MINT_WINDOW_MS=600000

# Jupiter
JUPITER_QUOTE_URL=https://quote-api.jup.ag/v6/quote
JUPITER_SWAP_URL=https://quote-api.jup.ag/v6/swap

# Runtime
LOG_LEVEL=info
METRICS_FLUSH_INTERVAL_MS=15000